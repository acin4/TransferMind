        {
          "name": "GET /api/teams/:id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const teamId = pm.environment.get(\"teamId\");",
                  "if (!teamId || teamId === \"__missing__\") {",
                  "  pm.test(\"Prerequisite teamId exists\", function () {",
                  "    pm.expect.fail(\"teamId is not set. Run 'GET /api/teams' first.\");",
                  "  });",
                  "  return;",
                  "}",
                  "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Response is JSON\", function () { pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\"); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Response has data or error\", function () {",
                  "  pm.expect(json).to.be.an(\"object\");",
                  "  pm.expect(Object.prototype.hasOwnProperty.call(json, \"data\") || Object.prototype.hasOwnProperty.call(json, \"error\")).to.equal(true);",
                  "});",
                  "pm.test(\"Response has data\", function () { pm.expect(json).to.have.property(\"data\"); });",
                  "pm.test(\"Returned team uses the requested internal id\", function () {",
                  "  pm.expect(String(json.data.id)).to.equal(String(teamId));",
                  "});"
                ]
              }
            }
          ],
