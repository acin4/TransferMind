    {
      "name": "Health or Smoke",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Response is JSON\", function () { pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\"); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Response has data or error\", function () {",
                  "  pm.expect(json).to.be.an(\"object\");",
                  "  pm.expect(Object.prototype.hasOwnProperty.call(json, \"data\") || Object.prototype.hasOwnProperty.call(json, \"error\")).to.equal(true);",
                  "});",
                  "pm.test(\"Response has data\", function () { pm.expect(json).to.have.property(\"data\"); });",
                  "pm.test(\"Response has grouped standings contract\", function () {",
                  "  pm.expect(json.data).to.be.an(\"object\");",
                  "  pm.expect(json.data).to.have.property(\"groups\").that.is.an(\"array\");",
                  "  pm.expect(json.data).to.have.property(\"selectedGroupKey\");",
                  "});",
                  "pm.test(\"Each group includes ids, priority, and sorted rows\", function () {",
                  "  json.data.groups.forEach(function (group) {",
                  "    pm.expect(group).to.include.keys([\"key\", \"label\", \"stage\", \"standingGroupId\", \"stageTournamentId\", \"priority\", \"rows\"]);",
                  "    pm.expect(group.rows).to.be.an(\"array\");",
                  "    for (let index = 1; index < group.rows.length; index += 1) {",
                  "      const previous = group.rows[index - 1].position == null ? Number.MAX_SAFE_INTEGER : group.rows[index - 1].position;",
                  "      const current = group.rows[index].position == null ? Number.MAX_SAFE_INTEGER : group.rows[index].position;",
                  "      pm.expect(current).to.be.at.least(previous);",
                  "    }",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Basic smoke check for the running backend."
          },
          "response": []
        }
      ]
    },
